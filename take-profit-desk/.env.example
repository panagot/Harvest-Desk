# Copy to `.env`. Never commit real secrets.

# Zerion agent API — get a key from https://dashboard.zerion.io/
# Optionally leave blank and rely on sibling file `../api` (single line).

ZERION_API_KEY=

# Zerion CLI path override (default: ../zerion-ai/cli/zerion.js)
# ZERION_CLI_PATH=

DESK_WALLET=demo-wallet

# Required for POST /api/execute from the UI — use a long random string locally.
EXECUTE_SECRET=change-me-to-a-long-random-string

# Set MOCK_MODE=true ONLY to force synthetic data (recording fallbacks).

MOCK_MODE=false
PORT=8787

# Optional: ZERION_API_KEY_FILE=C:\path\to\keyfile

# --- Autonomous cron tick (`npm run agent:tick`)
# Logs JSON lines. When FIRE and enabled, swaps via Zerion CLI (needs agent token on wallet).
AGENT_AUTO_EXECUTE=false

# --- Single-process prod: serve Vite `./dist` from same Express app
SERVE_STATIC=0

# --- Telegram bot (`npm run bot:telegram`)
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_IDS=123456789,987654321
